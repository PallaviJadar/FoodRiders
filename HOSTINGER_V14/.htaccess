# 🚀 FOODRIDERS PRODUCTION .HTACCESS (V16)
# Optimized for Hostinger Node.js Manager

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. SSL & WWW Redirect (Optional but recommended)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 2. Skip existing files/directories (Essential for /assets, /images, /uploads)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Direct everything else to the Node.js Application
    # Note: Hostinger handles the port 5000 proxying automatically 
    # if the "Application Startup File" is set to index.js.
    # If the site shows "index.js content", uncomment the line below:
    # RewriteRule ^(.*)$ index.js [L,QSA]
</IfModule>

# Stop Apache from listing directories
Options -Indexes

# Set correct MIME types for safety
AddType application/javascript .js
AddType text/css .css
AddType image/x-icon .ico
AddType application/json .json
AddType application/manifest+json .webmanifest
